<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="10dp">

    <TextView
        android:id="@+id/allQuestsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ВСЕ КВЕСТЫ"
        android:textColor="@color/bright_red"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/searchQuests"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/allQuestsTitle"
        android:background="@drawable/rounded_edittext_bg"
        android:hint="Поиск по названию..."
        android:paddingStart="15dp"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:layout_marginBottom="10dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/questsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/searchQuests" />

    <!-- Плюс справа внизу -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddQuestFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="Добавить новый квест"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/bright_red"
        app:tint="@color/white" />

</RelativeLayout>
