<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="20dp">

    <TextView
        android:id="@+id/actorsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:text="УПРАВЛЕНИЕ АКТЕРАМИ"
        android:textColor="@color/bright_red"
        android:textSize="24sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/actorsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/actorsTitle"
        android:layout_marginTop="10dp" />

    <!-- Красивая круглая кнопка Плюс внизу справа -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddActorFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="Добавить нового актера"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/bright_red"
        app:tint="@color/white" />

</RelativeLayout>
