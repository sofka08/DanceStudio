<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/editTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ДОБАВЛЕНИЕ АКТЕРА"
        android:textColor="@color/bright_red"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/etActorName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="ФИО Актера"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:background="@drawable/rounded_edittext_bg"
        android:paddingStart="15dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/etActorRole"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Роль"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:background="@drawable/rounded_edittext_bg"
        android:paddingStart="15dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/etActorContact"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Контакты"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:background="@drawable/rounded_edittext_bg"
        android:paddingStart="15dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/etActorImage"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Ссылка на фото"
        android:textColor="@color/white"
        android:textColorHint="#888888"
        android:background="@drawable/rounded_edittext_bg"
        android:paddingStart="15dp"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnSaveActor"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="СОХРАНИТЬ"
        android:backgroundTint="@color/bright_red"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"/>

</LinearLayout>
