<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/editQuestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КВЕСТ"
            android:textColor="@color/bright_red"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/editQuestName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название квеста"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editQuestDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Описание"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:gravity="top"
            android:lines="4"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editQuestCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Категория"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editQuestDifficulty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Сложность"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editQuestPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Цена"
            android:inputType="numberDecimal"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editQuestImageUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ссылка на картинку"
            android:textColor="@color/white"
            android:textColorHint="#888888"
            android:background="@drawable/rounded_edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnSaveQuest"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="СОХРАНИТЬ"
            android:backgroundTint="@color/bright_red"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>
