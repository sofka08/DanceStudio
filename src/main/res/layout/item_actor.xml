<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/gray"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/actorImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_image"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/actorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Имя Актера"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/actorRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Роль: Основной"
                android:textColor="@color/bright_red"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/actorContacts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Контакты: +7 (XXX) XXX-XX-XX"
                android:textColor="#BBBBBB"
                android:textSize="14sp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnEditActor"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_edit"
            android:layout_gravity="center_vertical"
            android:contentDescription="Редактировать актера"
            android:layout_marginEnd="8dp"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/btnDeleteActor"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_delete"
            android:layout_gravity="center_vertical"
            android:contentDescription="Удалить актера"
            app:tint="@color/white" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
