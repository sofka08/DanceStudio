<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:padding="15dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ОТЗЫВЫ"
        android:textColor="@color/bright_red"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="15dp"/>

    <LinearLayout
        android:id="@+id/layoutAddReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:padding="10dp"
        android:layout_marginBottom="15dp">

        <RatingBar
            android:id="@+id/ratingBarInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:progressTint="@color/bright_red" />

        <EditText
            android:id="@+id/etReviewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Напишите ваш отзыв..."
            android:textColor="@color/white"
            android:textColorHint="#888888" />

        <Button
            android:id="@+id/btnSendReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ОТПРАВИТЬ"
            android:backgroundTint="@color/bright_red" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reviewsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
