<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <!-- Цвет фона поля ввода -->
            <solid android:color="@color/gray_input_background" />
            <!-- Закругленные углы -->
            <corners android:radius="8dp" />
            <!-- Бордюр вокруг поля (опционально) -->
            <stroke android:width="1dp" android:color="@color/light_gray_border" />
        </shape>
    </item>
</selector>
